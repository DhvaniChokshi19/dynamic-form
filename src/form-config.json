{
  "fields": [
    {
      "type": "text",
      "label": "Full Name",
      "name": "fullName",
      "required": true,
      "placeholder": "Enter your full name"
    },
    {
      "type": "email",
      "label": "Email",
      "name": "email",
      "required": true,
      "placeholder": "Enter your email"
    },
    {
      "type": "password",
      "label": "Password",
      "name": "password",
      "required": true,
      "placeholder": "Enter your password"
    },
    {
      "type": "number",
      "label": "Age",
      "name": "age",
      "placeholder": "Enter your age"
    },
    {
      "type": "tel",
      "label": "Phone Number",
      "name": "phone",
      "placeholder": "Enter your phone number"
    },
    {
      "type": "date",
      "label": "Date of Birth",
      "name": "dob"
    },
    {
      "type": "radio",
      "label": "Gender",
      "name": "gender",
      "options": [
        "Male",
        "Female",
        "Other"
      ],
      "required": true
    },
    {
      "type": "select",
      "label": "Country",
      "name": "country",
      "required": true,
      "options": [
        "India",
        "USA",
        "Canada"
      ]
    },
    {
      "type": "textarea",
      "label": "About You",
      "name": "about",
      "placeholder": "Write something about yourself"
    },
    {
      "type": "file",
      "label": "Upload Resume",
      "name": "resume"
    },
    {
      "type": "checkbox",
      "label": "Subscribe to newsletter",
      "name": "subscribe"
    },
    {
      "type": "text",
      "label": "Company Name",
      "name": "company",
      "placeholder": "Enter company name",
      "showIf": {
        "field": "subscribe",
        "value": true
      }
    }
  ]
}